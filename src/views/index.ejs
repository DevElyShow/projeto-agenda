<%- include('includes/head') %>
<%- include('includes/nav') %>

<div class="container">
  <div class="row">
    <div class="col-lg-2"></div>

    <div class="col-lg-8 my-5">

      <div class="card shadow p-4">
        <h1 class="text-center mb-2">📒 Agenda</h1>
        <p class="text-center text-muted">Seus contatos estão abaixo</p>

        <form method="GET" action="/dashboard" class="mt-3">
        <div class="input-group">
       <input 
        type="text" 
        name="busca" 
        class="form-control" 
        placeholder="🔎 Buscar contato pelo nome..."
        value="<%= typeof busca !== 'undefined' ? busca : '' %>"
       >
    <button class="btn btn-dark" type="submit">Buscar</button>
  </div>
</form>

        <%- include('includes/messages') %>

        <% if(contatos.length > 0) { %>

        <div class="table-responsive mt-4">
          <table class="table table-hover align-middle">
            <thead class="table-dark">
              <tr>
                <th>Nome</th>
                <th>Sobrenome</th>
                <th>Telefone</th>
                <th>Email</th>
                <th class="text-center">Ações</th>
              </tr>
            </thead>

            <tbody>
              <% contatos.forEach(contato => { %>
              <tr>
                <td><%= contato.nome %></td>
                <td><%= contato.sobrenome %></td>
                <td><%= contato.telefone %></td>
                <td><%= contato.email %></td>
                <td class="text-center">
                  <a class="btn btn-warning btn-sm"
                     href="/contato/<%= contato._id %>">
                     Editar
                  </a>

                  <a class="btn btn-danger btn-sm"
                     href="/contato/delete/<%= contato._id %>"
                     onclick="return confirm('Tem certeza que deseja excluir este contato?')">
                     Excluir
                  </a>
                </td>
              </tr>
              <% }); %>
            </tbody>

          </table>
        </div>

       <!-- PAGINAÇÃO AQUI -->
<% if (totalPages > 1) { %>
<nav class="mt-4">
  <ul class="pagination justify-content-center">

    <% for(let i = 1; i <= totalPages; i++) { %>
      <li class="page-item <%= currentPage === i ? 'active' : '' %>">
        <a class="page-link" href="/dashboard?page=<%= i %>&busca=<%= busca %>">
          <%= i %>
        </a>
      </li>
    <% } %>

  </ul>
</nav>
<% } %>

<div class="text-end mt-3">
  <a href="/contato" class="btn btn-success">
    ➕ Novo Contato
  </a>
</div>

        <% } else { %>

        <div class="text-center mt-4">
          <h5 class="mb-3">Sua agenda está vazia 📭</h5>
          <a href="/contato" class="btn btn-primary btn-lg">
            ➕ Adicionar Primeiro Contato
          </a>
        </div>

        <% } %>

      </div>

    </div>
    
    <div class="col-lg-2"></div>
  </div>
</div>

<%- include('includes/footer') %>
